  "item": [
    {
      "name": "Creating a duplicate repository",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verify the status code of the duplicate repository request. \r",
              "pm.test(\"Verify the status code of the duplicate repository request\", function () {\r",
              "   pm.expect(pm.response.code).to.eql(422);\r",
              "});\r",
              "\r",
              "//Verify status message contains unprocessable entity. \r",
              "pm.test(\"Verify the status message of the duplicate repository request\", function () {\r",
              "    pm.expect(pm.response.status).to.include(\"Unprocessable Entity\");\r",
              "});\r",
              "\r",
              "//Verify the response time is less than 2 seconds. \r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "//Verify response body contains the message \"repository creation failed\". \r",
              "pm.test(\"Verify the error message in the response body\", function () {\r",
              "    let body = pm.response.json();\r",
              "    pm.expect(body.message).to.include(\"Repository creation failed.\");\r",
              "});\r",
              "\r",
              "//Verify response body contains the error message \"repository creation failed\". \r",
              "pm.test(\"Verify the error message in the response body\", function () {\r",
              "    let body = pm.response.json();\r",
              "    pm.expect(body.errors[0].message).to.include(\"name already exists on this account\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "accept",
            "value": "application/vnd.github+json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "{{TOKEN}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"JMeterRepo\",\r\n    \"description\":\"Sample Duplicate Repo From Postman\",\r\n    \"private\": true\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BASE_URL}}/user/repos",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
    },
